{
  "name": "Dory",
  "url": "https://dory.clidey.com",
  "description": "Static documentation site generator for modern teams. Build beautiful docs from MDX files.",
  "favicon": "./favicon.svg",
  "colors": {
    "primary": "#F1BF4F",
    "light": "#F1BF4F",
    "dark": "#F1BF4F",
    "background": "oklch(0.16 0.035 255)",
    "surface": "oklch(0.20 0.04 255)",
    "surfaceElevated": "oklch(0.24 0.05 255)",
    "foreground": "oklch(0.97 0.005 250)",
    "mutedForeground": "oklch(0.72 0.02 250)",
    "border": "oklch(0.7 0.08 250 / 14%)"
  },
  "theme": {
    "mode": "dark"
  },
  "fonts": {
    "family": "Inter Tight",
    "stylesheet": "https://fonts.googleapis.com/css2?family=Inter+Tight:wght@300;400;500;600;700&family=Fraunces:opsz,wght,SOFT@9..144,300..600,30..100&family=JetBrains+Mono:wght@400;500&display=swap",
    "heading": {
      "family": "Fraunces"
    },
    "mono": {
      "family": "JetBrains Mono"
    }
  },
  "logo": {
    "light": "./logo/logo.svg",
    "dark": "./logo/logo.svg"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "introduction",
              "getting-started/installation",
              "getting-started/quick-start",
              "getting-started/configuration"
            ]
          },
          {
            "group": "Components",
            "pages": [
              "components/overview",
              "components/typography",
              "components/code-blocks",
              "components/callouts",
              "components/cards",
              "components/accordion",
              "components/expandable",
              "components/steps",
              "components/tables",
              "components/lists",
              "components/icons",
              "components/tags",
              "components/images",
              "components/layout",
              "components/source",
              "components/mermaid",
              "components/latex"
            ]
          },
          {
            "group": "Interactive Playgrounds",
            "pages": [
              "playgrounds/api-playground",
              "playgrounds/websocket-playground"
            ]
          },
          {
            "group": "Configuration",
            "pages": [
              "configuration/dory-json",
              "configuration/navigation",
              "configuration/theming",
              "configuration/fonts",
              "configuration/analytics",
              "configuration/embed"
            ]
          }
        ]
      }
    ]
  }
}
